<?xml version="1.0" encoding="UTF-8"?>
<!--
    台北號誌時制：忠孝東路×敦化南路
    參考台北市交通局標準時制（非尖峰）：
      Phase 0：忠孝東路（EW）直行綠燈  70s
      Phase 1：EW 黃燈                   4s
      Phase 2：敦化南路（NS）直行綠燈  50s
      Phase 3：NS 黃燈                   4s
    合計週期 128s

    連結順序（state string 對應 connection 順序，由 netconvert 自動排列）
    此處以 tlLogic 定義預設時制，作為 LCPO agent 的初始基準。
    LCPO agent 會透過 TraCI 動態調整各 phase 的持續時間。
-->
<additional>
    <tlLogic id="center" type="static" programID="taipei_default" offset="0">
        <!--
            State string 每個字元對應一條連結：
            G = 綠燈（可走）
            g = 次要方向綠燈
            y = 黃燈
            r = 紅燈
            順序：EW直行(8) → EW左轉(2) → NS直行(6) → NS左轉(2)
        -->
        <!-- Phase 0：EW 直行 + NS 紅燈 -->
        <phase duration="70" state="GGGGGGGGrrrrrrrrrrrrrrrrGGGGGGGGrrrrrrrrrrrrrr"/>
        <!-- Phase 1：EW 黃燈 -->
        <phase duration="4"  state="yyyyyyyyrrrrrrrrrrrrrrrryyyyyyyyrrrrrrrrrrrrrr"/>
        <!-- Phase 2：NS 直行 + EW 紅燈 -->
        <phase duration="50" state="rrrrrrrrGGGGGGGGrrrrrrrrrrrrrrrrGGGGGGGGrrrrrr"/>
        <!-- Phase 3：NS 黃燈 -->
        <phase duration="4"  state="rrrrrrrryyyyyyyyrrrrrrrrrrrrrrrryyyyyyyyrrrrrr"/>
    </tlLogic>
</additional>
